<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>

    <Version>0.1.0-beta</Version>
    <PackageTags>AI; MCP; server; chart; plot; visualization</PackageTags>
    <Description>An HTTP MCP server that generates static chart images (bar, horizontal bar, stacked bar, line, pie, bubble) and returns signed image URLs.</Description>
    <ContainerRepository>sangyuxiaowu/generatechartmcpserver</ContainerRepository>
    <ContainerImageTags>0.1.0-beta;latest</ContainerImageTags>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Hosting" Version="10.0.0-preview.6.25358.103" />
    <PackageReference Include="ModelContextProtocol" Version="0.4.0-preview.1" />
    <PackageReference Include="ModelContextProtocol.AspNetCore" Version="0.4.0-preview.1" />
    <PackageReference Include="Sang.AspNetCore.SignAuthorization" Version="2.2.0" />
    <PackageReference Include="ScottPlot" Version="5.1.58" />
  </ItemGroup>

</Project>
